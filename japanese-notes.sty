% ---------- Learning-note commands ----------
% Two arguments: word, meaning.
% Three arguments: word, reading, meaning.
% Four arguments: word, reading, part of speech, meaning.
\NewDocumentCommand{\vocabentry}{m m g g}{%
  \IfNoValueTF{#3}{%
    #1 & \multicolumn{3}{>{\raggedright\arraybackslash}p{0.75\linewidth}@{}}{#2}\\
  }{%
    \IfNoValueTF{#4}{%
      #1 & #2 & \multicolumn{2}{>{\raggedright\arraybackslash}p{0.55\linewidth}@{}}{#3}\\
    }{%
      #1 & #2 & #3 & #4\\
    }%
  }%
  \hline
}

\newcommand{\sentence}[3]{%
  \noindent{\jpmincho\large #1}\par
  \vspace{1pt}
  {\jpmincho\small\color{JPGray}#2}\par
  \vspace{2pt}
  {\color{JPInk}#3}\par
}

\newcommand{\dialogueline}[3]{%
  \noindent
  \makebox[2.2em][l]{\sffamily\bfseries\color{JPGreen}#1}
  {\jpmincho #2}\par
  \hspace*{2.2em}{\small\color{JPGray}#3}\par
  \vspace{0.35em}
}

\newcommand{\answerline}[1][1]{%
  \par\noindent
  \foreach \n in {1,...,#1}{%
    \rule{\linewidth}{0.35pt}\par\vspace{1.45em}%
  }%
}

\newenvironment{vocabtable}{%
  \renewcommand{\arraystretch}{1.35}
  \setlength{\tabcolsep}{4pt}
  \rowcolors{2}{JPLightGray}{white}
  \begin{longtable}{@{}
    >{\jpmincho\bfseries}p{0.18\textwidth}
    >{\jpmincho}p{0.17\textwidth}
    >{\centering\arraybackslash\sffamily\small}p{0.10\textwidth}
    p{0.19\textwidth}
    >{\jpmincho}p{0.24\textwidth}
  @{}}
  \rowcolor{JPIndigo!16}
  {\mdseries\heiti 单词} & {\mdseries\heiti 读音} &
  {\mdseries\heiti 词性} & {\mdseries\heiti 释义} &
  {\mdseries\heiti 搭配 / 例句}\\
  \endfirsthead
  \rowcolor{JPIndigo!16}
  {\mdseries\heiti 单词} & {\mdseries\heiti 读音} &
  {\mdseries\heiti 词性} & {\mdseries\heiti 释义} &
  {\mdseries\heiti 搭配 / 例句}\\
  \endhead
}{%
  \end{longtable}
}

